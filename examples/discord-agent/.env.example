# Required
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_guild_id_here

# Identity
IDENTITY_ID=discord-agent
IDENTITY_NAME=Discord Agent
IDENTITY_CLASS=assistant
IDENTITY_STORAGE_PATH=/data/identities

# Scheduling
REMINDER_INTERVAL_MINUTES=30
DIGEST_TIME_DAILY=09:00
DIGEST_TIME_WEEKLY=09:00
DIGEST_DAY_WEEKLY=monday

# Runtime
TIMEZONE=UTC
LOG_LEVEL=INFO
HEALTHCHECK_PORT=8080
COMMAND_SYNC_ON_START=true
